rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if true;
    }
  
   // ฟังก์ชันอ่านแผนก
    function getUserDept() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.department;
    }

    // 🌟 1. ให้ ADMIN มีสิทธิ์สูงสุด จัดการได้ทุก Collection ในฐานข้อมูล
    match /{document=**} {
      allow read, write, delete: if request.auth != null && getUserDept() == 'ADMIN';
    }

    // 2. กฎปกติสำหรับพนักงานทั่วไป (Admin จะทะลุกฎนี้ไปเลยเพราะข้อ 1)
    match /molds/{moldId} {
      allow create: if request.auth != null && getUserDept() == 'PDD';
      allow read, update: if request.auth != null && 
        (getUserDept() == 'PDD' || getUserDept() == 'QCD' || getUserDept() == 'QAD');
    }
    
    // 3. กฎสำหรับอ่านข้อมูล Users ตัวเอง
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
    }
  }
}